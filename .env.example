# PsychedCMS - Global Environment Variables
# Copy this file to .env and adjust values as needed

# =============================================================================
# Docker Compose
# =============================================================================
COMPOSE_PROJECT_NAME=psyched-cms

# Host user UID/GID for permission matching in containers
# Run `id` to find your values
UID=1000
GID=1000

# =============================================================================
# Versions
# =============================================================================
PHP_VERSION=8.3
NODE_VERSION=20
POSTGRES_VERSION=16
NGINX_VERSION=alpine

# =============================================================================
# Symfony / PHP
# =============================================================================
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=!ChangeThisToASecureRandomString!

# =============================================================================
# Database
# =============================================================================
POSTGRES_USER=psyched
POSTGRES_PASSWORD=psyched
POSTGRES_DB=psyched
# DATABASE_URL is composed from the above values in docker-compose.yml

# =============================================================================
# Application Domain
# =============================================================================
# Add this domain to your /etc/hosts: 127.0.0.1 psychedcms.local
APP_DOMAIN=psychedcms.local
NGINX_PORT=80

# =============================================================================
# React Admin / Vite
# =============================================================================
VITE_API_URL=http://${APP_DOMAIN}/api

# =============================================================================
# Mercure (Real-time updates)
# =============================================================================
MERCURE_PORT=3000
MERCURE_URL=http://mercure/.well-known/mercure
MERCURE_PUBLIC_URL=http://${APP_DOMAIN}:${MERCURE_PORT}/.well-known/mercure
MERCURE_JWT_SECRET=!ChangeThisMercureHubJWTSecretKey!

# =============================================================================
# RabbitMQ (Message Queue)
# =============================================================================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
MESSENGER_TRANSPORT_DSN=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672/%2f/messages

# =============================================================================
# Optional Services
# =============================================================================

# MinIO (S3-compatible storage)
# Enable with: docker compose --profile storage up
MINIO_ROOT_USER=psyched
MINIO_ROOT_PASSWORD=psyched123
MINIO_BUCKET=psyched-media

# Elasticsearch
# Enable with: docker compose --profile search up
ELASTICSEARCH_URL=http://elasticsearch:9200
