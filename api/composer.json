{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../packages/psychedcms-calendar",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../packages/psychedcms-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../packages/psychedcms-media",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../packages/psychedcms-taxonomy",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../packages/psychedcms-translatable",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../packages/psychedcms-workflow",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "api-platform/core": "^4.2.20",
        "composer/installers": "^2.3",
        "doctrine/doctrine-bundle": "^2.18.2",
        "doctrine/doctrine-migrations-bundle": "^3.7",
        "doctrine/orm": "^3.6.2",
        "gedmo/doctrine-extensions": "^3.22",
        "league/flysystem-bundle": "^3.6.2",
        "nelmio/cors-bundle": "^2.6.1",
        "psychedcms/psychedcms-calendar": "@dev",
        "psychedcms/psychedcms-core": "@dev",
        "psychedcms/psychedcms-media": "@dev",
        "psychedcms/psychedcms-taxonomy": "@dev",
        "psychedcms/psychedcms-translatable": "@dev",
        "psychedcms/psychedcms-workflow": "@dev",
        "stof/doctrine-extensions-bundle": "^1.15.3",
        "symfony/amqp-messenger": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2.10",
        "symfony/framework-bundle": "7.4.*",
        "symfony/mercure-bundle": "^0.4.2",
        "symfony/messenger": "7.4.*",
        "symfony/mime": "7.4.*",
        "symfony/runtime": "7.4.*",
        "symfony/scheduler": "7.4.*",
        "symfony/validator": "7.4.*",
        "symfony/workflow": "7.4.*",
        "symfony/yaml": "7.4.*",
        "webonyx/graphql-php": "^15.30.2"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "composer/installers": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/",
            "PsychedCms\\Calendar\\Tests\\": "../packages/psychedcms-calendar/tests/",
            "PsychedCms\\Core\\Tests\\": "../packages/psychedcms-core/tests/",
            "PsychedCms\\Media\\Tests\\": "../packages/psychedcms-media/tests/",
            "PsychedCms\\Taxonomy\\Tests\\": "../packages/psychedcms-taxonomy/tests/",
            "PsychedCms\\Translatable\\Tests\\": "../packages/psychedcms-translatable/tests/",
            "PsychedCms\\Workflow\\Tests\\": "../packages/psychedcms-workflow/tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        },
        "installer-paths": {
            "vendor/psychedcms/{$name}": ["type:psychedcms"]
        }
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "phpunit/phpunit": "^12.5.14"
    }
}
